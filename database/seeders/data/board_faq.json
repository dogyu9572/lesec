    {
        "id": 5,
        "user_id": null,
        "title": "재발급",
        "content": "<p><span style=\"color: rgb(57, 57, 57); font-family: NotoSans, sans-serif; font-size: 16.1px; letter-spacing: normal; text-align: justify;\">수료증은 체험학습 당일 학생들에게 직접 전달합니다.<\/span><\/p><p style=\"margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px; color: rgb(57, 57, 57); font-family: NotoSans, sans-serif; font-size: 16.1px; letter-spacing: normal; text-align: justify;\">&nbsp;<\/p><p><span style=\"color: rgb(57, 57, 57); font-family: NotoSans, sans-serif; font-size: 16.1px; letter-spacing: normal; text-align: justify;\">분실, 추가 발급 등의 이유로 재발급 시에는 10,000원의 수수료가 발생합니다.(등기우편비용 포함)<\/span><\/p><p style=\"margin-right: 0px; margin-bottom: 0px; margin-left: 0px; padding: 0px; color: rgb(57, 57, 57); font-family: NotoSans, sans-serif; font-size: 16.1px; letter-spacing: normal; text-align: justify;\">&nbsp;<\/p><p><span style=\"color: rgb(57, 57, 57); font-family: NotoSans, sans-serif; font-size: 16.1px; letter-spacing: normal; text-align: justify;\">재발급 요청 시 전화(02-880-4948) 혹은 이메일(nicemedu@snu.ac.kr)로 연락바랍니다.<\/span><\/p>",
        "author_name": "관리자",
        "password": null,
        "is_notice": 0,
        "is_secret": 0,
        "is_active": 0,
        "category": "수료증",
        "attachments": "[]",
        "view_count": 0,
        "sort_order": 0,
        "custom_fields": null,
        "thumbnail": null,
        "created_at": "2025-12-03 16:55:07",
